<div class="row dataFile">
  <div class="col-sm-4">
    <input data-name='filename'  placeholder='Filename' class='editor-input' id='datafile<%= data.index %>filename' value='<%= data.filename %>'>
  </div>

  <div class="col-sm-4">
    <input data-name='format' placeholder='Format' class='editor-input' id='datafile<%= data.index %>format' value="<%= data.format %>">
  </div>

  <div class="col-sm-4">
    <input data-name='size'  placeholder='File size' class='editor-input' id='datafile<%= data.index %>Size' value='<%= data.size %>'>
  </div>
</div>